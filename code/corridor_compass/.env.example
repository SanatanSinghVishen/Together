# OpenRouter API Key (Preferred)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Alternatively, Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Server ports
OPERATOR_MEMORY_PORT=8001
PORTFOLIO_PULSE_PORT=8002
US_CORRIDOR_AUDITOR_PORT=8003

# LLM model configuration
DEFAULT_LLM_MODEL=google/gemini-2.0-flash
